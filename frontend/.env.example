# ── FastAPI Backend ───────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000

# ── NextAuth v5 ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_32_byte_random_secret
NEXTAUTH_URL=http://localhost:3000
# In production, set this to the actual deployed origin, e.g.
# NEXTAUTH_URL=https://your-domain.example.com
# trustHost:true is set in lib/auth.ts so hosts behind proxies/shared hosting
# (where the request Host header won't match NEXTAUTH_URL) are still accepted.

# ── BoxyHQ SAML Jackson ───────────────────────────────────────────────────────
# Self-host Jackson: docker run -p 5225:5225 boxyhq/jackson
# OR use the managed BoxyHQ cloud service.
#
# BOXYHQ_SAML_ISSUER is the Jackson base URL (the OAuth 2.0 issuer).
# BOXYHQ_SAML_ADMIN_SECRET is the Jackson admin API key for registering
# new enterprise tenant SSO configurations via the admin panel.
BOXYHQ_SAML_ISSUER=http://localhost:5225
BOXYHQ_SAML_ADMIN_SECRET=admin_secret_replace_me

# ── OAuth 2.0 credentials issued by BoxyHQ Jackson ───────────────────────────
# Obtain from the Jackson admin dashboard after deploying Jackson.
BOXYHQ_SAML_CLIENT_ID=saml_jackson_client_id
BOXYHQ_SAML_CLIENT_SECRET=saml_jackson_client_secret

# ── App ───────────────────────────────────────────────────────────────────────
# Shown in the "Enterprise SSO" tenant lookup.
# Matches the `product` field used when registering SSO configs in Jackson.
NEXT_PUBLIC_SAML_PRODUCT=rfp-responder
